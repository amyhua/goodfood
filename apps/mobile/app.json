{
  "expo": {
    "name": "goodfood",
    "slug": "goodfood",
    "scheme": "goodfood",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.goodfood.mobile"
    },
    "android": {
      "package": "app.goodfood.mobile",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "backgroundColor": "#166534"
      },
      "permissions": ["INTERNET"]
    },
    "extra": {
      "apiUrl": "https://goodfood.app"
    }
  }
}
