# ---------------------------------------------------------------------------
# goodfood environment. Copy to .env and fill in. NEVER commit real secrets.
# Server-only vars must never be exposed to the browser (no NEXT_PUBLIC_ prefix).
# ---------------------------------------------------------------------------

# Postgres (Neon). DATABASE_URL is pooled; DIRECT_URL is direct (migrations).
DATABASE_URL="postgresql://user:password@localhost:5432/goodfood?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/goodfood?schema=public"

# USDA FoodData Central API key (server-only). https://fdc.nal.usda.gov/api-key-signup.html
USDA_FDC_API_KEY=""

# Solver service base URL (server-only).
SOLVER_URL="http://localhost:8000"

# Auth secret (server-only). Generate: openssl rand -base64 32
AUTH_SECRET=""

# Optional: Vercel Blob storage for licensed food images.
# BLOB_READ_WRITE_TOKEN=""

# ---------------------------------------------------------------------------
# Orchestration only (not used by the app) — Linear tracking via GraphQL.
# LINEAR_API_KEY / LINEAR_TEAM_ID / LINEAR_TEAM_KEY live in .env (gitignored).
# ---------------------------------------------------------------------------

# Public origin for canonical + social share URLs (F3). Falls back to http://localhost:3000.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Discord community (F9). Both optional — features stay hidden/off until set.
NEXT_PUBLIC_DISCORD_URL=
DISCORD_WEBHOOK_URL=

# Monetization (F10) — ALL OFF/optional by default. App is 100% free unless MONETIZATION_ENABLED=true.
MONETIZATION_ENABLED=false
FREE_MONTHLY_PLAN_LIMIT=20
FREE_MONTHLY_LIST_LIMIT=20
PREMIUM_PRICE_USD=5
ADS_ENABLED=false
NEXT_PUBLIC_ADS_ENABLED=false
# Stripe test-mode (billing scaffold stays inert until both are set):
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
# Comma-separated admin emails allowed to open /admin/settings:
ADMIN_EMAILS=
