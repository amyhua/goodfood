# goodfood environment variables — copy to `.env` (gitignored) and fill in.
# Also add these as claude.ai/code environment secrets (cloud sessions) and Vercel env vars (deploys).
# NEVER commit the real .env. See docs/infrastructure.md.

# --- Linear (already provisioned: GoodFoodApp / team GOO) ---
LINEAR_API_KEY=
LINEAR_TEAM_ID=edc3a6c3-fb4c-4adf-9728-55e2fc03db80
LINEAR_TEAM_KEY=GOO

# --- Neon Postgres (Prisma) ---
# DATABASE_URL: POOLED connection (host contains "-pooler"), for app runtime.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/goodfood?sslmode=require&pgbouncer=true
# DIRECT_URL: DIRECT (non-pooled) connection, for prisma migrate.
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/goodfood?sslmode=require

# --- USDA FoodData Central (canonical nutrient source) ---
# Free key: https://fdc.nal.usda.gov/api-key-signup.html
FDC_API_KEY=

# --- Deferred (add when the relevant phase lands) ---
# Solver service base URL (FastAPI + OR-Tools), once hosted.
# SOLVER_URL=
# Supabase (only if/when auth or image storage is needed).
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
