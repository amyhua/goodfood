{
  "name": "@goodfood/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "prisma generate",
    "typecheck": "prisma generate && tsc --noEmit",
    "test": "prisma generate && vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "@goodfood/domain": "workspace:*"
  },
  "devDependencies": {
    "prisma": "^6.2.1",
    "typescript": "^5.7.2",
    "tsx": "^4.19.2",
    "vitest": "^3.0.5",
    "@types/node": "^22.10.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
