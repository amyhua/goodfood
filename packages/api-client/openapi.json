{
  "openapi": "3.1.0",
  "info": {
    "title": "goodfood-solver",
    "version": "0.1.0"
  },
  "paths": {
    "/health": {
      "get": {
        "summary": "Health",
        "description": "Liveness probe.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Health"
                }
              }
            }
          }
        }
      }
    },
    "/ready": {
      "get": {
        "summary": "Ready",
        "description": "Readiness probe (no external deps yet).",
        "operationId": "ready_ready_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Health"
                }
              }
            }
          }
        }
      }
    },
    "/solve": {
      "post": {
        "summary": "Solve Endpoint",
        "description": "Optimize a meal plan (selections only; TypeScript computes the canonical proof).",
        "operationId": "solve_endpoint_solve_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SolveRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SolveResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CandidateFood": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "meal_roles": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Meal Roles",
            "description": "meal roles this food may appear in"
          },
          "per100g": {
            "additionalProperties": {
              "anyOf": [
                {
                  "type": "number"
                },
                {
                  "type": "null"
                }
              ]
            },
            "type": "object",
            "title": "Per100G",
            "description": "nutrient key -> per-100g value; null == missing"
          },
          "tags": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Tags"
          },
          "category": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Category"
          },
          "is_pantry": {
            "type": "boolean",
            "title": "Is Pantry",
            "default": false
          },
          "pantry_grams": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Pantry Grams"
          },
          "min_grams": {
            "type": "number",
            "title": "Min Grams",
            "default": 0.0
          },
          "max_grams": {
            "type": "number",
            "title": "Max Grams",
            "default": 300.0
          }
        },
        "type": "object",
        "required": [
          "id",
          "name",
          "meal_roles"
        ],
        "title": "CandidateFood"
      },
      "ConstraintViolation": {
        "properties": {
          "key": {
            "type": "string",
            "title": "Key"
          },
          "kind": {
            "type": "string",
            "title": "Kind"
          },
          "needed": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Needed"
          },
          "achieved": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Achieved"
          },
          "suggestion": {
            "type": "string",
            "title": "Suggestion"
          }
        },
        "type": "object",
        "required": [
          "key",
          "kind",
          "suggestion"
        ],
        "title": "ConstraintViolation"
      },
      "Diagnostics": {
        "properties": {
          "candidate_count": {
            "type": "integer",
            "title": "Candidate Count"
          },
          "selected_count": {
            "type": "integer",
            "title": "Selected Count"
          },
          "binding_constraints": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Binding Constraints"
          },
          "notes": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Notes"
          }
        },
        "type": "object",
        "required": [
          "candidate_count",
          "selected_count"
        ],
        "title": "Diagnostics"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "Health": {
        "properties": {
          "status": {
            "type": "string",
            "title": "Status"
          },
          "service": {
            "type": "string",
            "title": "Service"
          },
          "version": {
            "type": "string",
            "title": "Version"
          }
        },
        "type": "object",
        "required": [
          "status",
          "service",
          "version"
        ],
        "title": "Health"
      },
      "Infeasibility": {
        "properties": {
          "explanation": {
            "type": "string",
            "title": "Explanation"
          },
          "violations": {
            "items": {
              "$ref": "#/components/schemas/ConstraintViolation"
            },
            "type": "array",
            "title": "Violations"
          }
        },
        "type": "object",
        "required": [
          "explanation"
        ],
        "title": "Infeasibility"
      },
      "LockedIngredient": {
        "properties": {
          "food_id": {
            "type": "string",
            "title": "Food Id"
          },
          "meal_role": {
            "type": "string",
            "title": "Meal Role"
          },
          "grams": {
            "type": "number",
            "title": "Grams"
          }
        },
        "type": "object",
        "required": [
          "food_id",
          "meal_role",
          "grams"
        ],
        "title": "LockedIngredient"
      },
      "MealResult": {
        "properties": {
          "role": {
            "type": "string",
            "title": "Role"
          },
          "items": {
            "items": {
              "$ref": "#/components/schemas/SelectedItem"
            },
            "type": "array",
            "title": "Items"
          }
        },
        "type": "object",
        "required": [
          "role"
        ],
        "title": "MealResult"
      },
      "MealSpec": {
        "properties": {
          "role": {
            "type": "string",
            "title": "Role"
          },
          "required": {
            "type": "boolean",
            "title": "Required",
            "default": true
          },
          "template_tags": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Template Tags",
            "description": "each tag must be covered by >=1 selected food"
          },
          "max_total_grams": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Total Grams"
          }
        },
        "type": "object",
        "required": [
          "role"
        ],
        "title": "MealSpec"
      },
      "NutrientConstraint": {
        "properties": {
          "key": {
            "type": "string",
            "title": "Key"
          },
          "mode": {
            "$ref": "#/components/schemas/NutrientMode"
          },
          "min": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Min"
          },
          "target": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Target"
          },
          "max": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max"
          },
          "tolerance_low_pct": {
            "type": "number",
            "title": "Tolerance Low Pct",
            "default": 10.0
          },
          "tolerance_high_pct": {
            "type": "number",
            "title": "Tolerance High Pct",
            "default": 10.0
          }
        },
        "type": "object",
        "required": [
          "key",
          "mode"
        ],
        "title": "NutrientConstraint"
      },
      "NutrientMode": {
        "type": "string",
        "enum": [
          "DISABLED",
          "MINIMUM",
          "TARGET",
          "MAXIMUM"
        ],
        "title": "NutrientMode"
      },
      "ObjectiveWeights": {
        "properties": {
          "pantry": {
            "type": "integer",
            "title": "Pantry",
            "default": 100
          },
          "food_count": {
            "type": "integer",
            "title": "Food Count",
            "default": 10
          },
          "deviation": {
            "type": "integer",
            "title": "Deviation",
            "default": 1
          }
        },
        "type": "object",
        "title": "ObjectiveWeights"
      },
      "SelectedItem": {
        "properties": {
          "food_id": {
            "type": "string",
            "title": "Food Id"
          },
          "name": {
            "type": "string",
            "title": "Name"
          },
          "grams": {
            "type": "number",
            "title": "Grams"
          },
          "from_pantry": {
            "type": "boolean",
            "title": "From Pantry",
            "default": false
          }
        },
        "type": "object",
        "required": [
          "food_id",
          "name",
          "grams"
        ],
        "title": "SelectedItem"
      },
      "SolveMode": {
        "type": "string",
        "enum": [
          "strict",
          "diagnostic"
        ],
        "title": "SolveMode"
      },
      "SolveRequest": {
        "properties": {
          "foods": {
            "items": {
              "$ref": "#/components/schemas/CandidateFood"
            },
            "type": "array",
            "title": "Foods"
          },
          "meals": {
            "items": {
              "$ref": "#/components/schemas/MealSpec"
            },
            "type": "array",
            "title": "Meals"
          },
          "nutrient_constraints": {
            "items": {
              "$ref": "#/components/schemas/NutrientConstraint"
            },
            "type": "array",
            "title": "Nutrient Constraints"
          },
          "banned_food_ids": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Banned Food Ids"
          },
          "locked_ingredients": {
            "items": {
              "$ref": "#/components/schemas/LockedIngredient"
            },
            "type": "array",
            "title": "Locked Ingredients"
          },
          "gram_increment": {
            "type": "integer",
            "title": "Gram Increment",
            "default": 5
          },
          "seed": {
            "type": "integer",
            "title": "Seed",
            "default": 0
          },
          "time_budget_sec": {
            "type": "number",
            "title": "Time Budget Sec",
            "default": 5.0
          },
          "mode": {
            "$ref": "#/components/schemas/SolveMode",
            "default": "strict"
          },
          "weights": {
            "$ref": "#/components/schemas/ObjectiveWeights"
          }
        },
        "type": "object",
        "required": [
          "foods",
          "meals"
        ],
        "title": "SolveRequest"
      },
      "SolveResponse": {
        "properties": {
          "status": {
            "$ref": "#/components/schemas/SolveStatus"
          },
          "feasible": {
            "type": "boolean",
            "title": "Feasible"
          },
          "meals": {
            "items": {
              "$ref": "#/components/schemas/MealResult"
            },
            "type": "array",
            "title": "Meals"
          },
          "nutrient_totals": {
            "additionalProperties": {
              "type": "number"
            },
            "type": "object",
            "title": "Nutrient Totals"
          },
          "objective_score": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Objective Score"
          },
          "solve_time_ms": {
            "type": "integer",
            "title": "Solve Time Ms",
            "default": 0
          },
          "seed": {
            "type": "integer",
            "title": "Seed",
            "default": 0
          },
          "diagnostics": {
            "$ref": "#/components/schemas/Diagnostics"
          },
          "infeasibility": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/Infeasibility"
              },
              {
                "type": "null"
              }
            ]
          }
        },
        "type": "object",
        "required": [
          "status",
          "feasible",
          "diagnostics"
        ],
        "title": "SolveResponse"
      },
      "SolveStatus": {
        "type": "string",
        "enum": [
          "OPTIMAL",
          "FEASIBLE",
          "INFEASIBLE",
          "TIME_LIMIT",
          "ERROR"
        ],
        "title": "SolveStatus"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}
